# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc
.venv/

# crawler runtime output (keep .gitkeep only)
크롤러/output/*
!크롤러/output/.gitkeep
!크롤러/output/images
크롤러/output/images/*
!크롤러/output/images/.gitkeep

# data/ runtime — crawled articles, user-edited prompts, settings.json.
# 시드(2026-0001 ~ 2026-0003)는 명시적으로 추적, 나머지는 무시.
data/articles/2026-[0-9][0-9][0-9][0-9].json
!data/articles/2026-0001.json
!data/articles/2026-0002.json
!data/articles/2026-0003.json
data/articles/images/*
!data/articles/images/.gitkeep
!data/articles/images/rate.png
data/config/settings.json
data/prompts/*.md

